<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingSetMakerDef>
    <defName>CA_CrossedRaidLootMaker</defName>
    <root Class="ThingSetMaker_MarketValue">
      <fixedParams>
        <filter>
          <thingDefs>
            <li>Silver</li>
            <li>MedicineIndustrial</li>
            <li>MedicineHerbal</li>
            <li>ComponentIndustrial</li>
            <li>MealSurvivalPack</li>
            <li>Steel</li>
          </thingDefs>
        </filter>
      </fixedParams>
    </root>
  </ThingSetMakerDef>

  <FactionDef ParentName="FactionBase">
    <defName>CA_CrossedFaction</defName>
    <label>The Marked Men</label>
    <description>The Marked Men are not shambling dead. They are living, intelligent infected who retain enough memory, tool use, language, and tactical instinct to hunt survivors, raid settlements, force breaches, and spread the Marked Virus through blood exposure.</description>
    <fixedName>The Marked Men</fixedName>
    <pawnSingular>Marked Man</pawnSingular>
    <pawnsPlural>Marked Men</pawnsPlural>
    <leaderTitle>Alpha</leaderTitle>
    <leaderForceGenerateNewPawn>false</leaderForceGenerateNewPawn>
    <fixedLeaderKinds>
      <li>CA_CrossedWarlord</li>
    </fixedLeaderKinds>
    <humanlikeFaction>true</humanlikeFaction>
    <permanentEnemy>true</permanentEnemy>
    <naturalEnemy>true</naturalEnemy>
    <hostileToFactionlessHumanlikes>true</hostileToFactionlessHumanlikes>
    <autoFlee>false</autoFlee>
    <canStageAttacks>true</canStageAttacks>
    <canUseAvoidGrid>false</canUseAvoidGrid>
    <canRequestTraders>false</canRequestTraders>
    <canRequestMilitaryAid>false</canRequestMilitaryAid>
    <canRequestOrbitalTrader>false</canRequestOrbitalTrader>
    <canGenerateQuestSites>false</canGenerateQuestSites>
    <raidsForbidden>false</raidsForbidden>
    <rescueesCanJoin>false</rescueesCanJoin>
    <listOrderPriority>-80</listOrderPriority>
    <settlementGenerationWeight>1</settlementGenerationWeight>
    <requiredCountAtGameStart>1</requiredCountAtGameStart>
    <startingCountAtWorldCreation>1</startingCountAtWorldCreation>
    <maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
    <configurationListOrderPriority>5</configurationListOrderPriority>
    <categoryTag>MarkedMen</categoryTag>
    <techLevel>Industrial</techLevel>
    <allowedCultures>
      <li MayRequire="Ludeon.RimWorld.Ideology">Kriminul</li>
    </allowedCultures>
    <fixedIdeo>true</fixedIdeo>
    <ideoName>The Marked One</ideoName>
    <ideoDescription>The Marked One is less a faith than a command that survives inside the fever. It teaches that the red cross is proof of selection: the infected remember enough to hunt, speak, and organize, while the unmarked are failed kin fit only to feed the spread. Every raid is a sermon, every corpse a warning, and every survivor taken alive is another chance for the world to wear the mark.</ideoDescription>
    <hiddenIdeo>true</hiddenIdeo>
    <forcedMemes>
      <li MayRequire="Ludeon.RimWorld.Ideology">Structure_Ideological</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">Supremacist</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">HumanPrimacy</li>
    </forcedMemes>
    <styles>
      <li MayRequire="Ludeon.RimWorld.Ideology">Morbid</li>
    </styles>
    <requiredPreceptsOnly>true</requiredPreceptsOnly>
    <factionNameMaker>NamerFactionPirate</factionNameMaker>
    <settlementNameMaker>NamerSettlementPirate</settlementNameMaker>
    <factionIconPath>MapIcons/TheMarkedMenMapIcon</factionIconPath>
    <settlementTexturePath>MapIcons/MarkedVillage/TheMarkedVillage</settlementTexturePath>
    <colorSpectrum>
      <li>(1, 1, 1)</li>
      <li>(1, 1, 1)</li>
      <li>(1, 1, 1)</li>
    </colorSpectrum>
    <backstoryFilters>
      <li>
        <categories>
          <li>Pirate</li>
        </categories>
      </li>
      <li>
        <categories>
          <li>Outlander</li>
        </categories>
        <commonality>0.35</commonality>
      </li>
      <li>
        <categories>
          <li>Tribal</li>
        </categories>
        <commonality>0.15</commonality>
      </li>
    </backstoryFilters>
    <allowedArrivalTemperatureRange>-80~80</allowedArrivalTemperatureRange>
    <basicMemberKind>CA_CrossedCivilian</basicMemberKind>
    <raidLootMaker>CA_CrossedRaidLootMaker</raidLootMaker>
    <raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 0.7)</li>
        <li>(400, 1)</li>
        <li>(1200, 1.35)</li>
        <li>(3000, 1.65)</li>
      </points>
    </raidCommonalityFromPointsCurve>
    <raidLootValueFromPointsCurve>
      <points>
        <li>(0, 40)</li>
        <li>(500, 120)</li>
        <li>(2000, 450)</li>
        <li>(6000, 1200)</li>
      </points>
    </raidLootValueFromPointsCurve>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(0, 45)</li>
        <li>(150, 80)</li>
        <li>(700, 180)</li>
        <li>(1500, 280)</li>
        <li>(4000, 10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <pawnGroupMakers>
      <li>
        <kindDef>Combat</kindDef>
        <commonality>140</commonality>
        <options>
          <CA_CrossedCivilian>30</CA_CrossedCivilian>
          <CA_CrossedScout>10</CA_CrossedScout>
          <CA_CrossedHunter>10</CA_CrossedHunter>
