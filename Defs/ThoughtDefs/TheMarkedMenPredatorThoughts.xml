<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThoughtDef>
    <defName>CA_FreshKillSatisfaction</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>1.5</durationDays>
    <stackLimit>3</stackLimit>
    <stackedEffectMultiplier>0.65</stackedEffectMultiplier>
    <stages>
      <li>
        <label>satisfying kill</label>
        <description>The rush of a clean kill. The hunt paid off.</description>
        <baseMoodEffect>4</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>CA_BloodthirstyCraving</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>7</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>bloodthirsty craving</label>
        <description>The hunger for violence grows. It has been too long since the last hunt.</description>
        <baseMoodEffect>-6</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>CA_OverwhelmingBloodlust</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>3</durationDays>
    <stackLimit>2</stackLimit>
    <stages>
      <li>
        <label>overwhelming bloodlust</label>
        <description>The battle consumed everything. There is only the kill.</description>
        <baseMoodEffect>6</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>CA_PredatorPatience</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>2</durationDays>
    <stackLimit>2</stackLimit>
    <stackedEffectMultiplier>0.7</stackedEffectMultiplier>
    <stages>
      <li>
        <label>predator's patience</label>
        <description>Watching. Waiting. The prey does not know it is already marked.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
