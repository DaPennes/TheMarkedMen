<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThoughtDef>
    <defName>CA_WitnessedCrossedTransformation</defName>
    <durationDays>6</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>witnessed Marked Men transformation</label>
        <description>I watched a person lose themselves to the Marked Virus. They were still alive when they became something else.</description>
        <baseMoodEffect>-8</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>CA_CrossedSocialTerror</defName>
    <thoughtClass>Thought_MemorySocial</thoughtClass>
    <durationDays>12</durationDays>
    <stackLimit>18</stackLimit>
    <stackLimitForSameOtherPawn>5</stackLimitForSameOtherPawn>
    <stackedEffectMultiplier>0.85</stackedEffectMultiplier>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <socialTargetDevelopmentalStageFilter>Baby, Child, Adult</socialTargetDevelopmentalStageFilter>
    <nullifyingHediffs>
      <li MayRequire="Ludeon.RimWorld.Anomaly">Inhumanized</li>
    </nullifyingHediffs>
    <stages>
      <li>
        <label>hunted by Marked Men</label>
        <baseOpinionOffset>-70</baseOpinionOffset>
      </li>
    </stages>
    <thoughtToMake>CA_CrossedSocialTerrorMood</thoughtToMake>
  </ThoughtDef>

  <ThoughtDef>
    <defName>CA_CrossedSocialTerrorMood</defName>
    <durationDays>3</durationDays>
    <stackLimit>6</stackLimit>
    <stackedEffectMultiplier>0.8</stackedEffectMultiplier>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <nullifyingHediffs>
      <li MayRequire="Ludeon.RimWorld.Anomaly">Inhumanized</li>
    </nullifyingHediffs>
    <stages>
      <li>
        <label>hunted by Marked Men</label>
        <description>A Marked Men infected spoke with human intent and made it clear there would be no bargaining, no mercy, and no safe place to hide.</description>
        <baseMoodEffect>-10</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
