<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ScenPartDef>
    <defName>CA_MarkedVillageStart</defName>
    <label>marked village founder</label>
    <description>Starts the colony with an immune marked founder and generates a compact tribal village around the landing site.</description>
    <category>StartingImportant</category>
    <scenPartClass>TheMarkedMen.ScenPart_MarkedVillageStart</scenPartClass>
    <summaryPriority>480</summaryPriority>
    <maxUses>1</maxUses>
    <canBeRandomlyAdded>false</canBeRandomlyAdded>
    <canBePlayerAddedRemoved>false</canBePlayerAddedRemoved>
  </ScenPartDef>

  <ScenarioDef ParentName="ScenarioBase">
    <defName>CA_MarkedVillageFounder</defName>
    <label>Marked Village Founder</label>
    <description>You are the only known survivor whose body rejected the Marked Virus without losing the rash. The mark remains across your face, but the fever never returns. Around you stands a small palisaded village: tribal in shape, industrial in memory, and exposed to every warband that still hunts the immune.</description>
    <scenario>
      <summary>One immune marked colonist starts in a tribal village with industrial technology.</summary>
      <playerFaction>
        <factionDef>PlayerColony</factionDef>
      </playerFaction>
      <parts>
        <li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
          <def>ConfigPage_ConfigureStartingPawns</def>
          <pawnCount>1</pawnCount>
          <pawnChoiceCount>8</pawnChoiceCount>
        </li>

        <li Class="ScenPart_PlayerPawnsArriveMethod">
          <def>PlayerPawnsArriveMethod</def>
          <method>Standing</method>
          <visible>false</visible>
        </li>

        <li Class="TheMarkedMen.ScenPart_MarkedVillageStart">
          <def>CA_MarkedVillageStart</def>
        </li>

        <li Class="ScenPart_StartingResearch">
          <def>StartingResearch</def>
          <project>Smithing</project>
        </li>
        <li Class="ScenPart_StartingResearch">
          <def>StartingResearch</def>
          <project>Machining</project>
        </li>
        <li Class="ScenPart_StartingResearch">
          <def>StartingResearch</def>
          <project>MicroelectronicsBasics</project>
        </li>

        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Silver</thingDef>
          <count>350</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MealSurvivalPack</thingDef>
          <count>20</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MedicineIndustrial</thingDef>
          <count>12</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>ComponentIndustrial</thingDef>
          <count>12</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Gun_Revolver</thingDef>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MeleeWeapon_Knife</thingDef>
          <stuff>Steel</stuff>
        </li>

        <li Class="ScenPart_GameStartDialog">
          <def>GameStartDialog</def>
          <text>The village remembers the night the Marked Men came. Everyone else who carried the rash burned with the fever, turned, or died. You did not.\n\nThe cross-shaped rash is still visible across your face, but your blood rejects the virus. The people who built these huts are gone, leaving you a palisade, a few industrial tools, and enough old knowledge to rebuild before the warbands find you again.</text>
          <closeSound>GameStartSting</closeSound>
        </li>
      </parts>
    </scenario>
  </ScenarioDef>
</Defs>
