<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <KCSG.SettlementLayoutDef Abstract="True" Name="CA_BaseCrossedSettlement" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
    <settlementSize>60,60</settlementSize>
    <avoidBridgeable>true</avoidBridgeable>
    <centerBuildings>
      <centerSize>60,60</centerSize>
      <spaceAround>1</spaceAround>
      <allowedStructures>
        <li>
          <count>0~1</count>
          <tag>CA_CrossedNest</tag>
        </li>
        <li>
          <count>1~3</count>
          <tag>CA_CrossedBarracks</tag>
        </li>
      </allowedStructures>
    </centerBuildings>
    <peripheralBuildings>
      <allowedStructures>
        <li>
          <count>0~2</count>
          <tag>CA_CrossedHolding</tag>
        </li>
      </allowedStructures>
    </peripheralBuildings>
    <roadOptions>
      <addLinkRoad>true</addLinkRoad>
      <linkRoadDef>Concrete</linkRoadDef>
    </roadOptions>
    <propsOptions>
      <scatterProps>true</scatterProps>
      <scatterMinDistance>6</scatterMinDistance>
      <scatterMaxAmount>80</scatterMaxAmount>
      <scatterPropsDefs>
        <li>Skullspike</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BinBag</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BoxLarge</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BarrelGreen</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_FilthBlood</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_FilthDirt</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_FilthBones</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BrickPile</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_ConcreteBags</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_Pipes</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_WoodenLogs</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_WoodenLogsLarge</li>
      </scatterPropsDefs>
    </propsOptions>
    <defenseOptions>
      <addEdgeDefense>true</addEdgeDefense>
      <addSandbags>true</addSandbags>
      <addTurrets>false</addTurrets>
      <pawnGroupMultiplier>3.0</pawnGroupMultiplier>
    </defenseOptions>
    <stockpileOptions>
      <stockpileValueMultiplier>1.5</stockpileValueMultiplier>
    </stockpileOptions>
  </KCSG.SettlementLayoutDef>

  <KCSG.SettlementLayoutDef ParentName="CA_BaseCrossedSettlement" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
    <defName>CA_CrossedWarCamp</defName>
    <centerBuildings>
      <centralBuildingTags>
        <li>CA_CrossedNest</li>
      </centralBuildingTags>
      <allowedStructures>
        <li>
          <count>1~3</count>
          <tag>CA_CrossedBarracks</tag>
        </li>
        <li>
          <count>0~4</count>
          <tag>CA_CrossedHolding</tag>
        </li>
      </allowedStructures>
    </centerBuildings>
    <peripheralBuildings>
      <allowedStructures>
        <li>
          <count>0~3</count>
          <tag>CA_CrossedHolding</tag>
        </li>
      </allowedStructures>
    </peripheralBuildings>
    <defenseOptions>
      <pawnGroupMultiplier>4.0</pawnGroupMultiplier>
    </defenseOptions>
  </KCSG.SettlementLayoutDef>

  <KCSG.SettlementLayoutDef ParentName="CA_BaseCrossedSettlement" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
    <defName>CA_CrossedInfectedNest</defName>
    <centerBuildings>
      <centralBuildingTags>
        <li>CA_CrossedNest</li>
      </centralBuildingTags>
      <allowedStructures>
        <li>
          <count>1~2</count>
          <tag>CA_CrossedBarracks</tag>
        </li>
        <li>
          <count>1~3</count>
          <tag>CA_CrossedHolding</tag>
        </li>
      </allowedStructures>
    </centerBuildings>
    <peripheralBuildings>
      <allowedStructures>
        <li>
          <count>0~2</count>
          <tag>CA_CrossedHolding</tag>
        </li>
      </allowedStructures>
    </peripheralBuildings>
    <defenseOptions>
      <pawnGroupMultiplier>2.5</pawnGroupMultiplier>
    </defenseOptions>
  </KCSG.SettlementLayoutDef>
</Defs>
