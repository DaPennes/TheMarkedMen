<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ============================================================
       CA_CrossedBase - Abstract base for all Crossed pawns
       ============================================================ -->
  <PawnKindDef Name="CA_CrossedBase" Abstract="True">
    <race>Human</race>
    <defaultFactionDef>CA_CrossedFaction</defaultFactionDef>
    <label>Crossed</label>
    <isFighter>true</isFighter>
    <backstoryCryptosleepCommonality>0</backstoryCryptosleepCommonality>
    <chemicalAddictionChance>0.03</chemicalAddictionChance>
    <combatEnhancingDrugsChance>0.15</combatEnhancingDrugsChance>
    <combatEnhancingDrugsCount>1</combatEnhancingDrugsCount>
    <invNutrition>0.7</invNutrition>
    <requiredWorkTags>
      <li>Violent</li>
    </requiredWorkTags>
    <disallowedTraits>
      <li>Kind</li>
      <li>Wimp</li>
    </disallowedTraits>
    <initialWillRange>0~1</initialWillRange>
    <initialResistanceRange>50~90</initialResistanceRange>
    <!-- Apparel will never be completely destroyed; minimal gear always present -->
    <apparelMoney>20~50</apparelMoney>
    <gearHealthRange>0.1~0.5</gearHealthRange>
    <apparelAllowHeadgearChance>0.1</apparelAllowHeadgearChance>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Civilian
       Role:  Recently infected civilians
       Threat: Very Low
       Look:  Tattered civilian clothes, no armor
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedCivilian</defName>
    <label>Crossed civilian</label>
    <labelPlural>Crossed civilians</labelPlural>
    <combatPower>80</combatPower>
    <!-- Almost no budget — ruins/basic civilian scraps only -->
    <apparelMoney>25~70</apparelMoney>
    <apparelAllowHeadgearChance>0.12</apparelAllowHeadgearChance>
    <gearHealthRange>0.1~0.45</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>Neolithic</li>
    </apparelTags>
    <!-- No armor whatsoever -->
    <weaponMoney>30~80</weaponMoney>
    <weaponTags>
      <li>NeolithicMeleeBasic</li>
      <li>NeolithicMeleeDecent</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Scout
       Role:  Fast roaming infected, light equipment
       Threat: Low
       Look:  Light clothing, hoodies, dusters, no heavy armor
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedScout</defName>
    <label>Crossed scout</label>
    <labelPlural>Crossed scouts</labelPlural>
    <combatPower>120</combatPower>
    <apparelMoney>45~110</apparelMoney>
    <apparelAllowHeadgearChance>0.22</apparelAllowHeadgearChance>
    <gearHealthRange>0.2~0.55</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>Neolithic</li>
    </apparelTags>
    <!-- Flak vest is very rare — not included in tags, left to RNG via low money -->
    <weaponMoney>80~180</weaponMoney>
    <weaponTags>
      <li>SimpleGun</li>
      <li>NeolithicRangedBasic</li>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Hunter
       Role:  Stalker, wilderness infected, tracker
       Threat: Low
       Look:  Leather, tribalwear, dusters, cowboy hats
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedHunter</defName>
    <label>Crossed hunter</label>
    <labelPlural>Crossed hunters</labelPlural>
    <combatPower>200</combatPower>
    <apparelMoney>70~180</apparelMoney>
    <apparelAllowHeadgearChance>0.28</apparelAllowHeadgearChance>
    <gearHealthRange>0.25~0.65</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>Neolithic</li>
    </apparelTags>
    <!-- No military armor — flak vest extremely rare from base money -->
    <weaponMoney>100~300</weaponMoney>
    <weaponTags>
      <li>Gun</li>
      <li>NeolithicRangedDecent</li>
      <li>NeolithicRangedBasic</li>
      <li>NeolithicMeleeBasic</li>
      <li>MedievalMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Shooter
       Role:  Ranged infantry, sidearms, SMGs
       Threat: Low-Medium
       Look:  Utility vests, tactical shirts, flak gear common
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedShooter</defName>
    <label>Crossed shooter</label>
    <labelPlural>Crossed shooters</labelPlural>
    <combatPower>180</combatPower>
    <apparelMoney>60~140</apparelMoney>
    <apparelAllowHeadgearChance>0.3</apparelAllowHeadgearChance>
    <gearHealthRange>0.3~0.75</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>IndustrialMilitaryBasic</li>
      <li>IndustrialAdvanced</li>
    </apparelTags>
    <!-- Flak vest and flak helmet possible through IndustrialMilitaryBasic tag -->
    <weaponMoney>120~280</weaponMoney>
    <weaponTags>
      <li>ShortShots</li>
      <li>SimpleGun</li>
      <li>Gun</li>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Raider
       Role:  Experienced violent infected, bandits
       Threat: Medium
       Look:  Mixed flak, plate, tactical gear, battle-worn
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedRaider</defName>
    <label>Crossed raider</label>
    <labelPlural>Crossed raiders</labelPlural>
    <combatPower>280</combatPower>
    <canBeSapper>true</canBeSapper>
    <apparelMoney>100~240</apparelMoney>
    <apparelAllowHeadgearChance>0.3</apparelAllowHeadgearChance>
    <gearHealthRange>0.35~0.8</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>Neolithic</li>
      <li>IndustrialMilitaryBasic</li>
      <li>MedievalMilitary</li>
    </apparelTags>
    <!-- Flak vest/helmet common via IndustrialMilitaryBasic; plate armor rare via MedievalMilitary -->
    <weaponMoney>150~400</weaponMoney>
    <weaponTags>
      <li>Gun</li>
      <li>MedievalMeleeDecent</li>
      <li>NeolithicMeleeBasic</li>
      <li>MedievalMeleeBasic</li>
      <li>GrenadeDestructive</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Soldier
       Role:  Former military, professional soldier
       Threat: Medium-High
       Look:  Military uniform, flak armor, combat helmets, always armed
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedSoldier</defName>
    <label>Crossed soldier</label>
    <labelPlural>Crossed soldiers</labelPlural>
    <combatPower>380</combatPower>
    <canBeSapper>true</canBeSapper>
    <apparelMoney>200~400</apparelMoney>
    <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
    <gearHealthRange>0.5~1.0</gearHealthRange>
    <apparelTags>
      <li>IndustrialMilitaryBasic</li>
      <li>IndustrialMilitaryAdvanced</li>
      <li>IndustrialAdvanced</li>
    </apparelTags>
    <!-- Always has military-grade armor (flak or better) -->
    <weaponMoney>250~800</weaponMoney>
    <weaponTags>
      <li>IndustrialGunAdvanced</li>
      <li>GunHeavy</li>
      <li>SimpleGun</li>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Brute
       Role:  Massive frontline infected, melee juggernaut
       Threat: High
       Look:  Heavy plate armor, medieval military gear, huge weapons
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedBrute</defName>
    <label>Crossed brute</label>
    <labelPlural>Crossed brutes</labelPlural>
    <combatPower>420</combatPower>
    <canBeSapper>true</canBeSapper>
    <apparelMoney>180~380</apparelMoney>
    <apparelAllowHeadgearChance>0.85</apparelAllowHeadgearChance>
    <gearHealthRange>0.5~1.1</gearHealthRange>
    <apparelTags>
      <li>MedievalMilitary</li>
      <li>IndustrialMilitaryBasic</li>
      <li>IndustrialMilitaryAdvanced</li>
    </apparelTags>
    <!-- Heavy plate armor common via MedievalMilitary; marine armor rare via IndustrialMilitaryAdvanced -->
    <weaponMoney>250~650</weaponMoney>
    <weaponTags>
      <li>MedievalMeleeAdvanced</li>
      <li>MedievalMeleeDecent</li>
      <li>NeolithicMeleeBasic</li>
      <li>MedievalMeleeBasic</li>
      <li>SimpleGun</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Pyromaniac
       Role:  Fire-obsessed infected
       Threat: Medium
       Look:  Burned civilian clothing, minimal armor
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedPyromaniac</defName>
    <label>Crossed pyromaniac</label>
    <labelPlural>Crossed pyromaniacs</labelPlural>
    <combatPower>260</combatPower>
    <apparelMoney>60~180</apparelMoney>
    <apparelAllowHeadgearChance>0.12</apparelAllowHeadgearChance>
    <gearHealthRange>0.25~0.7</gearHealthRange>
    <apparelTags>
      <li>IndustrialBasic</li>
      <li>Neolithic</li>
      <li>IndustrialAdvanced</li>
    </apparelTags>
    <!-- No armor focus — looks like a burned civilian -->
    <chemicalAddictionChance>0.35</chemicalAddictionChance>
    <combatEnhancingDrugsChance>0.25</combatEnhancingDrugsChance>
    <weaponMoney>400~1000</weaponMoney>
    <weaponTags>
      <li>Flamethrower</li>
      <li>GrenadeFlame</li>
      <li>SimpleGun</li>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Alpha
       Role:  Elite infected leader
       Threat: Very High
       Look:  High-end tactical armor, recon/marine, command presence
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedAlpha</defName>
    <label>Crossed alpha</label>
    <labelPlural>Crossed alphas</labelPlural>
    <combatPower>750</combatPower>
    <canBeSapper>true</canBeSapper>
    <maxGenerationAge>65</maxGenerationAge>
    <apparelMoney>250~500</apparelMoney>
    <apparelAllowHeadgearChance>0.95</apparelAllowHeadgearChance>
    <gearHealthRange>0.7~1.3</gearHealthRange>
    <apparelTags>
      <li>IndustrialMilitaryAdvanced</li>
      <li>SpacerMilitary</li>
      <li>IndustrialAdvanced</li>
    </apparelTags>
    <!-- Guaranteed marine/recon armor via IndustrialMilitaryAdvanced + SpacerMilitary -->
    <combatEnhancingDrugsChance>0.5</combatEnhancingDrugsChance>
    <combatEnhancingDrugsCount>1~2</combatEnhancingDrugsCount>
    <weaponMoney>400~1400</weaponMoney>
    <weaponTags>
      <li>SpacerGun</li>
      <li>IndustrialGunAdvanced</li>
      <li>GunHeavy</li>
      <li>MedievalMeleeAdvanced</li>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Crossed Warlord
       Role:  Commander of infected groups
       Threat: Extreme
       Look:  Marine armor, cataphract pieces, command helmet
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_CrossedWarlord</defName>
    <label>Crossed warlord</label>
    <labelPlural>Crossed warlords</labelPlural>
    <combatPower>1200</combatPower>
    <canBeSapper>true</canBeSapper>
    <maxGenerationAge>70</maxGenerationAge>
    <apparelMoney>400~800</apparelMoney>
    <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
    <gearHealthRange>0.85~1.5</gearHealthRange>
    <apparelTags>
      <li>IndustrialMilitaryAdvanced</li>
      <li>SpacerMilitary</li>
      <li>MedievalMilitary</li>
    </apparelTags>
    <!-- High-end marine/cataphract gear -->
    <combatEnhancingDrugsChance>0.7</combatEnhancingDrugsChance>
    <combatEnhancingDrugsCount>2~3</combatEnhancingDrugsCount>
    <weaponMoney>300~2500</weaponMoney>
    <weaponTags>
      <li>GunHeavy</li>
      <li>SpacerGun</li>
      <li>IndustrialGunAdvanced</li>
      <li>MedievalMeleeAdvanced</li>
      <li>NeolithicMeleeBasic</li>
      <li>GrenadeDestructive</li>
    </weaponTags>
  </PawnKindDef>

  <!-- ============================================================
       Marked Man
       Role:  Legendary apex infected, endgame boss
       Threat: Endgame
       Look:  Cataphract-level armor, shield belt, instantly recognizable
       ============================================================ -->
  <PawnKindDef ParentName="CA_CrossedBase">
    <defName>CA_MarkedMan</defName>
    <label>Marked Man</label>
    <labelPlural>Marked Men</labelPlural>
    <combatPower>1800</combatPower>
    <canBeSapper>true</canBeSapper>
    <maxGenerationAge>75</maxGenerationAge>
    <!-- High budget guarantees spacer/military top-tier picks -->
    <apparelMoney>600~1200</apparelMoney>
    <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
    <gearHealthRange>0.95~2.0</gearHealthRange>
    <apparelTags>
      <li>SpacerMilitary</li>
      <li>IndustrialMilitaryAdvanced</li>
    </apparelTags>
    <apparelRequired>
      <li>Apparel_ShieldBelt</li>
    </apparelRequired>
    <combatEnhancingDrugsChance>0.9</combatEnhancingDrugsChance>
    <combatEnhancingDrugsCount>2~4</combatEnhancingDrugsCount>
    <techHediffsChance>0.5</techHediffsChance>
    <techHediffsMoney>500~5000</techHediffsMoney>
    <techHediffsTags>
      <li>Simple</li>
      <li>Advanced</li>
      <li>Neolithic</li>
      <li>Industrial</li>
      <li>Spacer</li>
      <li>Ultra</li>
    </techHediffsTags>
    <weaponMoney>400~4000</weaponMoney>
    <weaponTags>
      <li>SpacerGun</li>
      <li>GunHeavy</li>
      <li>IndustrialGunAdvanced</li>
      <li>MedievalMeleeAdvanced</li>
      <li>NeolithicMeleeBasic</li>
      <li>GrenadeDestructive</li>
    </weaponTags>
  </PawnKindDef>
</Defs>
