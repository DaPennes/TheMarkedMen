<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>CA_CrossVirus</defName>
    <label>Marked Virus</label>
    <description>A contagious neurological blood-borne disease spread by close contact with infected bodily fluids, contaminated blood, infected corpses, and tainted food. Marked Virus resistance from masks, sealed suits, and armor can reduce exposure risk and delay breakthrough infections. Fully sealed warcasket bodies, HAZMAT suits, and complete vacsuit sets block direct exposure, but they do not change toxic environment resistance. The virus usually overwhelms a victim quickly. A very small number of survivors develop lasting immune resistance; most terminal cases either transform into Marked Men or die from viral collapse.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <initialSeverity>0.08</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <lethalSeverity>1.5</lethalSeverity>
    <tendable>true</tendable>
    <isBad>true</isBad>
    <makesSickThought>true</makesSickThought>
    <alwaysShowSeverity>true</alwaysShowSeverity>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <label>rapid incubation</label>
        <becomeVisible>true</becomeVisible>
        <painFactor>0.9</painFactor>
        <statFactors>
          <MoveSpeed>1.03</MoveSpeed>
          <MeleeCooldownFactor>0.96</MeleeCooldownFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>-0.02</MentalBreakThreshold>
          <PainShockThreshold>0.03</PainShockThreshold>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>active symptoms</label>
        <becomeVisible>true</becomeVisible>
        <painFactor>0.85</painFactor>
        <statFactors>
          <ImmunityGainSpeed>0.8</ImmunityGainSpeed>
          <RestRateMultiplier>0.85</RestRateMultiplier>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>-0.03</MentalBreakThreshold>
          <PainShockThreshold>0.04</PainShockThreshold>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.45</minSeverity>
        <label>neurological fever</label>
        <painFactor>0.35</painFactor>
        <statFactors>
          <MoveSpeed>1.08</MoveSpeed>
          <MeleeCooldownFactor>0.9</MeleeCooldownFactor>
          <SocialImpact>0.35</SocialImpact>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>-0.08</MentalBreakThreshold>
          <PainShockThreshold>0.10</PainShockThreshold>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.72</minSeverity>
        <label>violent psychosis</label>
        <painFactor>0.12</painFactor>
        <blocksInspirations>true</blocksInspirations>
        <statFactors>
          <MoveSpeed>1.20</MoveSpeed>
          <MeleeCooldownFactor>0.76</MeleeCooldownFactor>
          <IncomingDamageFactor>0.9</IncomingDamageFactor>
          <PsychicSensitivity>0.55</PsychicSensitivity>
          <StaggerDurationFactor>0.65</StaggerDurationFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>-0.22</MentalBreakThreshold>
          <PainShockThreshold>0.35</PainShockThreshold>
          <MeleeHitChance>2</MeleeHitChance>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Talking</capacity>
            <postFactor>0.45</postFactor>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.95</minSeverity>
        <label>irreversible marking</label>
        <painFactor>0</painFactor>
        <blocksMentalBreaks>true</blocksMentalBreaks>
        <blocksInspirations>true</blocksInspirations>
        <pctAllThoughtNullification>1</pctAllThoughtNullification>
        <statFactors>
          <MoveSpeed>1.32</MoveSpeed>
          <MeleeCooldownFactor>0.58</MeleeCooldownFactor>
          <IncomingDamageFactor>0.75</IncomingDamageFactor>
          <PsychicSensitivity>0.25</PsychicSensitivity>
          <StaggerDurationFactor>0.35</StaggerDurationFactor>
        </statFactors>
        <statOffsets>
          <MentalBreakThreshold>-0.50</MentalBreakThreshold>
          <PainShockThreshold>0.65</PainShockThreshold>
          <MeleeHitChance>5</MeleeHitChance>
          <MeleeDodgeChance>3</MeleeDodgeChance>
          <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
          <AimingDelayFactor>-0.18</AimingDelayFactor>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="TheMarkedMen.HediffCompProperties_CrossVirus">
        <incubationTicks>600</incubationTicks>
        <commonTransformationMinTicks>900</commonTransformationMinTicks>
        <commonTransformationMaxTicks>2400</commonTransformationMaxTicks>
        <rareSlowProgressionChance>0.02</rareSlowProgressionChance>
        <rareTransformationMinTicks>3600</rareTransformationMinTicks>
        <rareTransformationMaxTicks>7200</rareTransformationMaxTicks>
        <symptomOnsetFraction>0.15</symptomOnsetFraction>
        <immunityChance>0.05</immunityChance>
        <terminalTransformationChance>0.7894737</terminalTransformationChance>
        <transformedSeverity>1</transformedSeverity>
      </li>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>18</baseTendDurationHours>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>CA_CrossedRash</defName>
    <label>marked rash</label>
    <description>Deprecated compatibility marker from older saves. Marked Men pawns now use the marked face tattoo instead of hediff render overlays.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <label>deprecated</label>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CA_CrossVirusImmunity</defName>
    <label>marked-virus immunity</label>
    <description>This pawn has strong Marked Virus immune memory. Ordinary acquired immunity blocks reinfection; starter-lineage resistance can very rarely fail after direct exposure.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <label>immune</label>
        <statFactors>
          <ImmunityGainSpeed>1.05</ImmunityGainSpeed>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CA_BloodRush</defName>
    <label>blood rush</label>
    <description>The infected pawn's adrenal system is locked into a sprinting combat state.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <stages>
      <li>
        <painFactor>0</painFactor>
        <blocksMentalBreaks>true</blocksMentalBreaks>
        <statFactors>
          <MoveSpeed>1.45</MoveSpeed>
          <MeleeCooldownFactor>0.56</MeleeCooldownFactor>
          <IncomingDamageFactor>0.9</IncomingDamageFactor>
          <StaggerDurationFactor>0.25</StaggerDurationFactor>
        </statFactors>
        <statOffsets>
          <MeleeHitChance>6</MeleeHitChance>
          <MeleeDodgeChance>4</MeleeDodgeChance>
          <PainShockThreshold>0.25</PainShockThreshold>
          <MentalBreakThreshold>-0.25</MentalBreakThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CA_CommandAura</defName>
    <label>alpha command aura</label>
    <description>An Alpha's vocal cadence and pheromone output pushes nearby infected into coordinated violence.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <stages>
      <li>
        <painFactor>0</painFactor>
        <blocksMentalBreaks>true</blocksMentalBreaks>
        <statFactors>
          <MoveSpeed>1.18</MoveSpeed>
          <MeleeCooldownFactor>0.68</MeleeCooldownFactor>
          <PsychicSensitivity>0.15</PsychicSensitivity>
          <StaggerDurationFactor>0.35</StaggerDurationFactor>
        </statFactors>
        <statOffsets>
          <ShootingAccuracyPawn>3</ShootingAccuracyPawn>
          <MeleeHitChance>3</MeleeHitChance>
          <MeleeDodgeChance>2</MeleeDodgeChance>
          <AimingDelayFactor>-0.25</AimingDelayFactor>
          <PainShockThreshold>0.25</PainShockThreshold>
          <MentalBreakThreshold>-0.25</MentalBreakThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CA_CrossedPanic</defName>
    <label>marked panic</label>
    <description>Recent contact with Marked Men voices, laughter, or coordinated threats has destabilized this pawn.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <stages>
      <li>
        <mentalBreakMtbDays>0.75</mentalBreakMtbDays>
        <statFactors>
          <GlobalLearningFactor>0.7</GlobalLearningFactor>
          <WorkSpeedGlobal>0.8</WorkSpeedGlobal>
        </statFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>18000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>
</Defs>
