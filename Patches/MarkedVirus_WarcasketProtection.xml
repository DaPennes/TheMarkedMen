<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <!-- Warcasket torso shells: fully sealed combat caskets with high resistance -->
      <li Class="PatchOperationConditional">
        <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and apparel/bodyPartGroups/li="Torso" and not(contains(defName, "Shoulders")) and not(contains(defName, "Bodysuit")) and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and apparel/bodyPartGroups/li="Torso" and not(contains(defName, "Shoulders")) and not(contains(defName, "Bodysuit")) and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]/modExtensions</xpath>
          <value>
            <li Class="TheMarkedMen.MarkedVirusProtectionExtension">
              <resistance>0.85</resistance>
              <sealedAgainstMarkedVirus>true</sealedAgainstMarkedVirus>
              <blocksMarkedVirusExposure>false</blocksMarkedVirusExposure>
            </li>
          </value>
        </match>
      </li>

      <!-- Warcasket bodysuit variants: full-body undersuits that are sealed -->
      <li Class="PatchOperationConditional">
        <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and contains(defName, "Bodysuit") and apparel/bodyPartGroups/li="Torso" and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and contains(defName, "Bodysuit") and apparel/bodyPartGroups/li="Torso" and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]/modExtensions</xpath>
          <value>
            <li Class="TheMarkedMen.MarkedVirusProtectionExtension">
              <resistance>0.70</resistance>
              <sealedAgainstMarkedVirus>true</sealedAgainstMarkedVirus>
              <blocksMarkedVirusExposure>false</blocksMarkedVirusExposure>
            </li>
          </value>
        </match>
      </li>

      <!-- Warcasket helmets: sealed headgear with good filtration -->
      <li Class="PatchOperationConditional">
        <xpath>/Defs/*[apparel and modExtensions and contains(defName, "WarcasketHelmet") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>/Defs/*[apparel and modExtensions and contains(defName, "WarcasketHelmet") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]/modExtensions</xpath>
          <value>
            <li Class="TheMarkedMen.MarkedVirusProtectionExtension">
              <resistance>0.25</resistance>
              <sealedAgainstMarkedVirus>true</sealedAgainstMarkedVirus>
            </li>
          </value>
        </match>
      </li>

      <!-- Warcasket shoulders/arms: armored limb coverings with basic protection -->
      <li Class="PatchOperationConditional">
        <xpath>/Defs/*[apparel and modExtensions and contains(defName, "WarcasketShoulders") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>/Defs/*[apparel and modExtensions and contains(defName, "WarcasketShoulders") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]/modExtensions</xpath>
          <value>
            <li Class="TheMarkedMen.MarkedVirusProtectionExtension">
              <resistance>0.15</resistance>
              <sealedAgainstMarkedVirus>false</sealedAgainstMarkedVirus>
            </li>
          </value>
        </match>
      </li>

      <!-- Any other warcasket part not covered above (arms, legs, etc.) -->
      <li Class="PatchOperationConditional">
        <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>/Defs/*[apparel and modExtensions and contains(defName, "Warcasket") and not(modExtensions/li[@Class="TheMarkedMen.MarkedVirusProtectionExtension"])]/modExtensions</xpath>
          <value>
            <li Class="TheMarkedMen.MarkedVirusProtectionExtension">
              <resistance>0.10</resistance>
              <sealedAgainstMarkedVirus>false</sealedAgainstMarkedVirus>
            </li>
          </value>
        </match>
      </li>
    </operations>
  </Operation>
</Patch>
