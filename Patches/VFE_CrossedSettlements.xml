<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>OskarPotocki.VanillaFactionsExpanded.Core</li>
    </mods>

    <match Class="PatchOperationFindMod">
      <mods>
        <li>VanillaExpanded.BaseGeneration</li>
      </mods>

      <match Class="PatchOperationAddModExtension">
        <xpath>/Defs/FactionDef[defName="CA_CrossedFaction"]</xpath>
        <value>
          <li Class="KCSG.CustomGenOption">
            <chooseFromSettlements>
              <li>VBGE_CA_CrossedWarCamp</li>
              <li>VBGE_CA_CrossedInfectedNest</li>
            </chooseFromSettlements>
            <preventBridgeable>true</preventBridgeable>
            <symbolResolvers>
              <li>kcsg_randomfilth</li>
            </symbolResolvers>
            <filthTypes>
              <li>Filth_Dirt</li>
              <li>Filth_Trash</li>
              <li>Filth_RubbleBuilding</li>
              <li>Filth_Blood</li>
            </filthTypes>
          </li>
        </value>
      </match>

      <nomatch Class="PatchOperationAddModExtension">
        <xpath>/Defs/FactionDef[defName="CA_CrossedFaction"]</xpath>
        <value>
          <li Class="KCSG.CustomGenOption">
            <chooseFromSettlements>
              <li>CA_CrossedWarCamp</li>
              <li>CA_CrossedInfectedNest</li>
            </chooseFromSettlements>
            <preventBridgeable>true</preventBridgeable>
            <symbolResolvers>
              <li>kcsg_randomfilth</li>
            </symbolResolvers>
            <filthTypes>
              <li>Filth_Dirt</li>
              <li>Filth_Trash</li>
              <li>Filth_RubbleBuilding</li>
              <li>Filth_Blood</li>
            </filthTypes>
          </li>
        </value>
      </nomatch>
    </match>
  </Operation>
</Patch>
