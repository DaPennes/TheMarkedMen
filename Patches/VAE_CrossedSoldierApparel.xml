<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>VanillaExpanded.VAPPE</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <!-- Crossed Soldier: ensure headgear + VAE apparel tag -->
        <li Class="PatchOperationConditional">
          <xpath>/Defs/PawnKindDef[defName="CA_CrossedSoldier"]/apparelAllowHeadgearChance</xpath>
          <match Class="PatchOperationReplace">
            <xpath>/Defs/PawnKindDef[defName="CA_CrossedSoldier"]/apparelAllowHeadgearChance</xpath>
            <value>
              <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
            </value>
          </match>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/PawnKindDef[defName="CA_CrossedSoldier"]</xpath>
            <value>
              <apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
            </value>
          </nomatch>
        </li>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/PawnKindDef[defName="CA_CrossedSoldier"]/apparelTags/li[text()="IndustrialMilitary"]</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/PawnKindDef[defName="CA_CrossedSoldier"]/apparelTags</xpath>
            <value>
              <li>IndustrialMilitary</li>
            </value>
          </nomatch>
        </li>

